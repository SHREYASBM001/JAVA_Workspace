package com.dsa.strings;

public class LongestSubstringWithoutRepeatingCharacter {

	public static void main(String[] args) {
		String s="pwwkew";
		int max=0;
		String s1="";
		int i=0;
		while(i<s.length()) {
			char current=s.charAt(i);
			if(s1.contains(current+"")) {
				s1=s1.substring(1);
			}
			s1+=current;
			if(max<s1.length()) {
				max=s1.length();
			}
			i++;
			
		}

		System.out.println(s1)
	}

}
