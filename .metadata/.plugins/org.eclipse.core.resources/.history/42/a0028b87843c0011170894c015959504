package com.empty;

public class Halfrev {

	public static void main(String[] args) {
		System.out.println(halfRev("Qspiaders"));

	}

	static String halfRev(String s) {
		int i=0;
		String s1="";
		int j=s.length()/2-1;
		while(j>=0) {
			char c =s.charAt(j);
			s1+=c+"";
			j--;
		}
		i=s.length()/2+1;
		j=s.length()-1;
		while(j>=i) {
			char c=s.charAt(j);
			s1+=c+"";
			j--;
		}
		return s1;
	}
}
