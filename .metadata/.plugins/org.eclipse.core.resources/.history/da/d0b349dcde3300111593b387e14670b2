package com.p1;

public class CountWordsInASentenceWithoutUsingSplit {

	public static void main(String[] args) {
		String s="JAVA is a Very Very EASY";
		char[] ch=s.toCharArray();
		String temp="";
		int count=0;
		
		int i=0;
		while(i<ch.length){
			while(i<ch.length && ch[i]!=' ') {
				temp+=ch[i]+" ";
				i++;
			}
			i++;
			if(!(temp.equals(""))) {
				count++;
			}
			temp="";
		}
		System.out.println(count);

	}

}
