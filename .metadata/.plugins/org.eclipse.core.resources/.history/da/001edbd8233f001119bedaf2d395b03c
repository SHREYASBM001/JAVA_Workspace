package com.empty;

public class BinarySearch {

	public static void main(String[] args) {
		System.out.println(find(new int[] {1,2,3,4},4));

	}
	static int find(int [] arr,int key) {
		int start=0;
		int end=arr.length-1;
		int i=0;
		while(start<=end) {
			if(i>arr.length-1) return -1;
			int mid=(start+end)/2;
			if(arr[mid]==key) {
				return mid;
			}
			else if(key<arr[mid]) {
				end=mid;
			}
			else {
				start=mid;
			}
			i++;
		}
		return -1;
	}

}
