package com.empty;

public class LowerToUpperAndUpperToLower {

	public static void main(String[] args) {
		System.out.println(convert("lowerUPPER"));

	}
	static String convert(String s) { 
		String s1="";
		
		int i=0;
		while(i<s.length()) {
			char c=s.charAt(i);
			if(c>='A' && c<='Z') s1+=c+('a'-'A');
			else if(c>='a' && c<='z') s1+=c-('a'-'A');
		}
		return s1;
	}

}
