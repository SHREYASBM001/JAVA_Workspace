package com.empty;

public class SmaxOC {

	public static void main(String[] args) {
		System.out.println(smaxOC("jaavva"));

	}
	static String smaxOC(String s) {
		String s1="";
		String s2="";
		int m1=0;
		int m2=0;
		int i=0;
		while(i<s.length()) {
			char c=s.charAt(i);
			int count=s.length()-s.replace(c+"","").length();
			if(count>m1 && count>m2 && !s1.contains(c+"")) {
				m2=count;
				s2=c+"";
			}
			if(count>m1) {
				s2=s1;
				s1=c+"";
				m2=m1;
				m1=count;
			}
			
			i++;
		}
		return s2+":"+m2;
						
		
	}
}
