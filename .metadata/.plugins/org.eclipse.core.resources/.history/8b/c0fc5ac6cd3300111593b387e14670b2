package com.stringconcepts;

public class P1 {

	public static void main(String[] args) {
		String s="aaabcbcddd";
		String s1="";
		char[] ch=s.toCharArray();
		String temp="";
		int count =1;
		int i=0;
		while(i<ch.length) {
			s="aaabcbcddd";
			char c=ch[i];
			temp=c+"";
			i++;
			while(i<ch.length && ch[i]==c) {
				count++;
				i++;
			}
			s1+=s.length(s.replace(s,temp))+temp;
			count=1;
		}
		System.out.println(s1);

	}

}
