package com.empty;

public class BinarySearchRec {

	public static void main(String[] args) {
		int[] arr= {1,2,3,4};
		int st=0;int end=arr.length-1;
		System.out.println(find(arr,4,st,end));

	}
	static int find(int[] arr,int key,int st,int end) {
		if(st>end) return -1;
		int mid=(st+end)/2;
		if(arr[mid]==key) return mid;
		else if(key<arr[mid]) {
			return find(arr,key,mid-1,end);
		}
		else {
			return find(arr,key,mid+1;end);
		}
	}
}
