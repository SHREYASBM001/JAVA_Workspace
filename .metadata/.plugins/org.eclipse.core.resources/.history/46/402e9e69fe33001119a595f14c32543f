package com.p1;

public class PrintTheOccuranceOfEachWord {

	public static void main(String[] args) {
		String s="java is very very easy java";
		String[] str=s.split(" ");
		int count=0;
		int i=0;
		String temp="";
		String fin="";
		while(i<str.length) {
			temp=str[i];
			for(String s1:str) {
				if(s1.equals(temp)) {
					count++;
					i++;
				}
			}
			fin=temp+"="+count+" ";
			i++;
			count=0;
		}
		System.out.println(fin.trim());
		

	}

}
