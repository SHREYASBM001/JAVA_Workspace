package com.empty;

public class BinarySearch {

	public static void main(String[] args) {
		System.out.println(find(new int[] {1,2,3,4},11));

	}
	static int find(int [] arr,int key) {
		int start=0;
		int end=arr.length-1;
		while(start<=end) {
			int mid=(start+end)/2;
			if(arr[mid]==key) {
				return mid;
			}
			else if(key<arr[mid]) {
				end=mid;
			}
			else {
				start=mid;
			}
		}
		return -1;
	}

}
