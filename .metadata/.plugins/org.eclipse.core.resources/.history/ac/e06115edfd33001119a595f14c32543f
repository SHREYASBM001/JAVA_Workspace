package com.p1;

public class PrintTheOccuranceOfEachWord {

	public static void main(String[] args) {
		String s="java is very very easy java";
		String[] str=s.split(" ");
		int count=1;
		int i=0;
		String temp="";
		String fin="";
		while(i<str.length) {
			temp=str[i];
			i++;
			while(i<str.length && str[i].equals(temp)) {
				count++;
				i++;
			}
			fin=temp+"="+count+" ";
			
			count=1;
		}
		System.out.println(fin.trim());
		

	}

}
