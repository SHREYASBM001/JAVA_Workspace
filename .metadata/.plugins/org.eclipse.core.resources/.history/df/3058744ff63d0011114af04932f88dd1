public class PrintMaxOC {

	public static void main(String[] args) {
		System.out.println(printmaxOC("jaaavva"));

	}
	static String printmaxOC(String s) {
		String s1="";
		int i=0;
		int max=0;
		while(i<s.length()) {
			char c=s.charAt(i);
			if(s.length()-s.replace(c+"","").length()>max) {
				s1=c+"";
				max=s.length()-s.replace(c+"","").length();
			}
			i++;	
		}
	}

}
