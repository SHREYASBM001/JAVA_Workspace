package com.dsa.strings;

public class PrintSecondMaxOccuredCharacter {
	//input:"jaaavva"
	//output:v=2
	public static void main(String[] args) {
		String s="jaaavva";
		String s1="";
		
		int max=Integer.MIN_VALUE;
		int secondmax=Integer.MIN_VALUE;
		for(int i=0;i<s.length();i++) {
			char c=s.charAt(i);
			int count=s.length()-s.replace(c+"","").length();
			if(count>secondmax &&! (s1.contains(c+""))) {
				secondmax=count;
				s1=c+"";
			}
			else if(count>max) {
				secondmax=max;
				max=count;
				
			}
			
		}

		System.out.println(s1);
	}

}
