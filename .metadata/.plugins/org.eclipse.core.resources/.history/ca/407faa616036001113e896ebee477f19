package com.dsa.strings;

public class PrintMaxOccuredCharacter {

	public static void main(String[] args) {
		String s="jbbbbbbvaaaa";
		int count=s.length();
		String s1="";
		int i=0;
		while(i<s.length()) {
			char c=s.charAt(i);
			i++;
			while(i<s.length() && s.charAt(i)==c) {
			s1+=c+"";
			count++;
			i++;
			}
			
		}
		System.out.println(s1+":"+count);

	}

}
