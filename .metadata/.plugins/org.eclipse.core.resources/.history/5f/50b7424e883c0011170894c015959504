package com.empty;

public class TakeFullNumberAndAdd {

	public static void main(String[] args) {
	System.out.printnln(addNums("add123with123"));

	}
	static int addNums(String s) {
		int sum=0;
		int i=0;
		while(i<s.length()) {
			int parts=0;
			while(i<s.length() && (s.charAt(i)>='0' && s.charAt(i)<='9')) {
				parts=(parts*10)+(s.charAt(i)-'0');
				i++;
			}
			i++;
			sum+=parts;
		}
	}

}
