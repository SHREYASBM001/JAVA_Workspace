package com.dsa.strings;

public class LongestSubstringWithoutRepeatingCharacter {

	public static void main(String[] args) {
		String s="pwwkew";
		String t="bbbbbb";
		int max=0;
		String s1="";
		System.out.println(lengthOfLongestSubstringWithoutRepeatingCharacter(s));
		System.out.println(lengthOfLongestSubstringWithoutRepeatingCharacter(t));
		
		for(int i=0;i<s.length();i++) {
			char current=s.charAt(i);
			while(s1.contains(current+"")) {
				s1=s1.substring(1);
			}
			s1+=current;
			if(s1.length()>max) {
				max=s1.length();
			}
			
		}

		System.out.println(s1);
	}
	static int lengthOfLongestSubstringWithoutRepeatingCharacter(String s) {
		String s1="";
		int max=0;
		for(int i=0;i<s.length();i++) {
			char current=s.charAt(i);
			while(s1.contains(current+"")) {
				s1=s1.substring(1);
			}
			
			s1+=current;
			if(s1.length()>max) {
				max=s1.length();
			}
			
		}
		return max;
	}
	

}
