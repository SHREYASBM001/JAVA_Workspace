package com.dsa.arrays;

public class PrintDistinctElementsInTwoArray {

	public static void main(String[] args) {
		/*example:
		 * input:
		 * a={2,1,3};
		 * b={4,5,1,2,3};
		 * output:
		 * {4,5}
		 * */
		int [] arr= {2,1,3,5,3,3,2,5};
		int [] arr2= {4,5,1,2,3};
		String s="";
		
		
			for(int i=0;i<arr2.length;i++) {
				boolean flag=true;
				for(int j=0;j<arr.length;j++) {
					
					if(arr2[i]==arr[j]) {
						flag=false;
					}
				}
				if(flag) {
					s+="{"+arr2[i]+"}";
				}
			}
			System.out.println(s);
			
		}

	}

}
