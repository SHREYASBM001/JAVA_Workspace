package com.empty;

public class LargestPalSubs {

	public static void main(String[] args) {
		System.out.println(largest("malayalam"));

	}
	static String largest(String s) {
		char[] c=s.toCharArray();
		int max=0;
		String s1="";
		for(int i=0;i<s.length();i++) {
			for(int j=i+1;j<c.length;j++) {
				if(isP(c,i,j)) {
					if(s.substring(i,j+1).length()>max){
						s1=s.substring(i,j+1);
						max=s1.length();
					}
				}
			}
		}
		return s1;
		
	}
	static boolean isP(char[] c,int start,int end) {
		while(start<end) {
			if(c[start]!=c[end]) return false;
			start++;
			end--;
		}
		return true;
	}	
}
