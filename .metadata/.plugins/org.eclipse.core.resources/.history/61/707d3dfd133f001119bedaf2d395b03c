package com.empty;

public class PrintLeaderd {

	public static void main(String[] args) {
		prints(new int[] {16,17,3,5,2});

	}
	static void prints(int [] arr) {
		for(int i=0;i<arr.length;i++) { boolean flag=true;
			for(int j=i+1;j<arr.length;j++) {
				if(arr[i]> arr[j]) {
					flag=false;
					break;
				}
			}
			if(flag) System.out.println(arr[i]);
		}
	}
}
