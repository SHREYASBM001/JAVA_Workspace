package com.dsa.arrays;

public class PrintTheCharacterHavingOneOccurances {

	public static void main(String[] args) {
		char[] ch= {'a','v','e','v'};
		boolean flag=true;
		
		for(int i=0;i<ch.length;i++) {
			
			for(int j=0;j<ch.length;j++) {
				
				if(ch[i]==ch[j]) {
					flag=false;
					
				}
			}
			
			if(flag)
			System.out.println(ch[i]);
		}

	}

}
