package com.dsa.arrays;

import java.util.Arrays;

public class PrintDistinctElementsInTwoArray {

	public static void main(String[] args) {
		/*example:
		 * input:
		 * a={2,1,3};
		 * b={4,5,1,2,3};
		 * output:
		 * {4,5}
		 * */
		int [] arr= {2,1,3,3,5,4,};
		int [] arr2= {4,5,1,2,3};
		String s="";
		int[] fin;
		if(arr.length>arr2.length) {
		fin=new int[arr.length];
		} else {
		fin=new int[arr2.length];
			
		}
		int l=0;
		for(int i=0;i<arr.length;i++) {
			
			boolean flag=true;
			for(int j=0;j<arr2.length;j++) {
				
				if(arr[i]==arr2[j]) {
					flag=false;
				}
			}
		
				for(int k=0;k<fin.length;k++) {
					if(fin[k]==arr[i]) {
						flag=false;
					}
					
					
				}
				if(flag) {
					fin[l]=arr[i];
					l++;
				}
					
				
			
			
			
		}
		System.out.println(Arrays.toString(fin));
		

	}

}
