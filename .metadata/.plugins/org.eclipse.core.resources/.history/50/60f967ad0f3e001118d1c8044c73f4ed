package nonprimitivecompare;

class Emp implements Comparable {
	String name;
	double bal;
	
	Emp(String name,double bal){
		this.name=name;
		this.bal=bal;
		
	}
	@Override
	public int compareTo(Object o) {
		return name.compareTo(((Emp)o).name);
	}
	
}
public class Test {
	public static void main(String [] o) {
		Emp[] e=new Emp[3];
		e[0]=new Emp("Naresh",37000);
		e[1]=new Emp("Suresh",26000);
		e[2]=new Emp("zuresh",13000);
	}
}
