package com.dsa.strings;

public class IfNumberOfVowelsAreGreaterThanTwoReplaceThemWithUnderscore {

	public static void main(String[] args) {
		String s="javadev";
		char[] ch=s.toCharArray();
		String s1="";
		String vowel="aeiou";
		int i=0;
		while(i<vowel.length()) {
			char c=vowel.charAt(i);
			
			for(int j=0;j<ch.length;j++) {
				
				int count=s.length()-s.replace(c+"","").length();
				if(count>1 && s.charAt(j)==c) {
					ch[j]='_';
					
				}
			}
			i++;
			
		}
		System.out.println(new String(ch));
	}

}
