package com.logica;
import java.util.Scanner;
public class PrintSecondLargestPrime {

	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		System.out.println("Enter the number");
		int n=sc.nextInt();
		
		System.out.println(printLargestPrime(n));
	}
static int printLargestPrime(int n) {
	 if(n<2) {
		 System.out.println("Invalid number");
		 return 0;

	 } int i=n;
	 	

	 while(i<=n && i>1) {
		 boolean flag=true;
		 int j=2;
		 while(j<=i/2) {
			 if(i%j==0) {
				 flag=false;
				 
			 }
			 j++;
		 }
		 if(flag) return i;
		 i--;
	 }
	 return 0;
	
}
}
