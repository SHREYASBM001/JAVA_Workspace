package com.dsa.strings;

public class PrintSecondMaxOccuredCharacter {
	//input:"jaaavva"
	//output:v=2
	public static void main(String[] args) {
		String s="jaaavva";
		String s1="";
		int count=0;
		int max=0;
		for(int i=0;i<s.length();i++) {
			char c=s.charAt(i);
			count=s.replace(c+"","").length();
			if((count<max && count>max-2)) {
				s1=c+"";
				
			}
		}

		System.out.println(s1);
	}

}
