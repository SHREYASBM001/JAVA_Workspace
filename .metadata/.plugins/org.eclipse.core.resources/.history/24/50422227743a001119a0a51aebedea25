package com.empty;

public class HalfReverse {

	public static void main(String[] args) {
		String s="Jspiaders";
		int i=s.length()/2-1;
		int j=0;
		String s1="";
		
		while(i>=0) {
			s1+=s.charAt(i);
			i--;
		}
		i=s.length()-1;
		j=s.length()/2;
		if(s.length()%2!=0) {
			s1+=s.charAt(s.length()/2);
			j=s.length()/2;
		}
		while(i>j) {
			s1+=s.charAt(i);
			i--;
		}
		System.out.println(s1);
		
	}

}
